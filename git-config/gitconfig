[user]
    name  = Jakob
    email = jakob.dekleva@gmail.com

[commit]
   gpgsign = true

# If the repo is anywhere under ~/devrev/, include the WORK config
[includeIf "gitdir:~/flare/"]
    path = ~/.gitconfig-work

# If the repo is anywhere under ~/jakob/, include the PERSONAL config
[includeIf "gitdir:~/jakob/"]
    path = ~/.gitconfig-personal

# If the repo is anywhere under ~/jakob-stuff/, include the PERSONAL config
[includeIf "gitdir:~/jakob-stuff/"]
    path = ~/.gitconfig-personal

# GPG program will be found automatically in PATH
# No need to hardcode /usr/bin/gpg in NixOS
[credential "https://github.com"]
	helper = 
	helper = !/etc/profiles/per-user/bine/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/etc/profiles/per-user/bine/bin/gh auth git-credential
[credential "https://gitlab.com"]
	helper = 
	helper = !/nix/store/k6cvfxidpfl59xw86lggm1s6gsy1jk3m-glab-1.74.0/bin/.glab-wrapped auth git-credential
